<Page x:Class="ParfumAdmin_WPF.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E"
      Loaded="Page_Loaded">

    <Page.Resources>

        <Style x:Key="StatCardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter/>
                            <Border x:Name="HoverHint"
                                    BorderBrush="#7C3AED"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverHint" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Áttekintés és analitikai adatok"
                               FontSize="13"
                               Foreground="#888"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="↻ Frissítés"
                        Command="{Binding RefreshCommand}"
                        Padding="14,8"
                        VerticalAlignment="Center"/>
            </Grid>


            <TextBlock Grid.Row="1"
                       Text="Adatok betöltése..."
                       Foreground="#888"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,40,0,0"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>


            <UniformGrid Grid.Row="1"
                         Rows="1" Columns="3"
                         Margin="0,0,0,24"
                         Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">


                <Button Style="{StaticResource StatCardButton}" Click="StatBox_Click" Margin="0,0,12,0">
                    <Border Background="#2A2A3E" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="👤 Mai látogatók"
                                       Foreground="#888"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TodayUniqueVisitors}"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                            <TextBlock Text="egyedi látogató ma"
                                       Foreground="#666"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>


                <Button Style="{StaticResource StatCardButton}" Click="StatBox_Click" Margin="6,0,6,0">
                    <Border Background="#2A2A3E" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="👁 Mai oldalmegtekintések"
                                       Foreground="#888"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TodayPageviews}"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding TodaySessions, StringFormat={}{0} session}"
                                       Foreground="#666"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>


                <Button Style="{StaticResource StatCardButton}" Click="StatBox_Click" Margin="12,0,0,0">
                    <Border Background="#3D2B6B" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="⚡ Aktív most"
                                       Foreground="#C4B5FD"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding ActiveSessions}"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                            <TextBlock Text="aktív az elmúlt 5 percben"
                                       Foreground="#9D8FBF"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>

            </UniformGrid>


            <UniformGrid Grid.Row="2"
                         Rows="1" Columns="3"
                         Margin="0,0,0,24"
                         Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">


                <Button Style="{StaticResource StatCardButton}" Click="StatBox_Click" Margin="0,0,12,0">
                    <Border Background="#2A2A3E" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="📅 Heti látogatók"
                                       Foreground="#888"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding WeekUniqueVisitors}"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding WeekPageviews, StringFormat={}{0} oldalmegtekintés · 7 nap}"
                                       Foreground="#666"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>


                <Button Style="{StaticResource StatCardButton}" Click="StatBox_Click" Margin="6,0,6,0">
                    <Border Background="#2A2A3E" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🆕 Új látogatók"
                                       Foreground="#888"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding WeekNewVisitors}"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                            <TextBlock Text="elmúlt 7 nap"
                                       Foreground="#666"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>


                <Button Style="{StaticResource StatCardButton}" Click="StatBox_Click" Margin="12,0,0,0">
                    <Border Background="#2A2A3E" CornerRadius="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="📊 Havi látogatók"
                                       Foreground="#888"
                                       FontSize="12"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding MonthUniqueVisitors}"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding MonthPageviews, StringFormat={}{0} oldalmegtekintés · 30 nap}"
                                       Foreground="#666"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Button>

            </UniformGrid>


            <Border Grid.Row="3"
                    Background="#2A2A3E"
                    CornerRadius="10"
                    Padding="20"
                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="🏆 Top 10 legtöbbet eladott termék (elmúlt 30 nap)"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>


                    <DataGrid ItemsSource="{Binding TopProducts}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              Foreground="White"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#252535"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#333"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              Sorting="DataGrid_Sorting">

                        <DataGrid.ColumnHeaderStyle>

                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                                <Setter Property="Padding" Value="8,8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderBrush" Value="#333"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Grid>
                                                <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="8" Cursor="SizeWE">
                                                    <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate></Thumb.Template>
                                                </Thumb>

                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"/>
                                                        <TextBlock x:Name="SortArrow"
                                                                   Grid.Column="1"
                                                                   Margin="6,0,0,0"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#7C3AED"
                                                                   Text=""/>
                                                    </Grid>
                                                </Border>

                                                <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="8" Cursor="SizeWE">
                                                    <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate></Thumb.Template>
                                                </Thumb>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="SortDirection" Value="Ascending">
                                                    <Setter TargetName="SortArrow" Property="Text" Value="▲"/>
                                                </Trigger>
                                                <Trigger Property="SortDirection" Value="Descending">
                                                    <Setter TargetName="SortArrow" Property="Text" Value="▼"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsDeletedProduct}" Value="True">
                                        <Setter Property="Foreground" Value="#888"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2E2E4E"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3D2B6B"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Termék"
                                                Binding="{Binding DisplayName}"
                                                SortMemberPath="Product.Name"
                                                Width="*"/>
                            <DataGridTextColumn Header="Kategória"
                                                Binding="{Binding Product.Category.Name}"
                                                Width="140"/>
                            <DataGridTextColumn Header="Ár"
                                                Binding="{Binding Product.Price, StringFormat={}{0:N0} Ft}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Eladva"
                                                Binding="{Binding SoldQty, StringFormat={}{0:N0} db}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Bevétel"
                                                Binding="{Binding TotalRevenue, StringFormat={}{0:N0} Ft}"
                                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
