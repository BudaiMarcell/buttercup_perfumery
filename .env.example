# ── Laravel ──
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_artisan_key_generate

# ── MySQL ──
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=parfum
MYSQL_USER=parfum
MYSQL_PASSWORD=change-me-app-password

# ── Mail ──
# `log` writes every outbound mail to storage/logs/laravel.log so you can
# eyeball verify/reset-password/order-placed/new-coupon templates without
# wiring a real provider. Switch to `smtp` (with the host/user/pass below)
# when you're ready to actually send. Mailable templates live under
# api/resources/views/emails/.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@buttercupperfumery.local

# ── Sentry ──
SENTRY_LARAVEL_DSN=
SENTRY_DSN_FRONTEND=

# ── Frontend tracking ──
TRACKING_KEY=

# ── Public hostnames (production only) ─────────────────────────────
# Leave these UNSET for local dev — docker-compose.yml falls back to
# the `*.local` placeholders. In production, fill in your real domain
# so Laravel generates correct absolute URLs in emails, Sanctum CSRF
# accepts the right Origin, and the Vue bundle calls the real API.
#
# APP_URL                = where the API answers (used by signed URLs)
# FRONTEND_URL           = where the Vue site lives (used inside mails)
# SANCTUM_STATEFUL_DOMAINS = comma-separated, must include the SPA host
# PUBLIC_API_URL         = baked into window.__CONFIG__.API_URL at boot
#
# Example for a deployed site behind Cloudflare:
# APP_URL=https://api.buttercupperfumery.com
# FRONTEND_URL=https://buttercupperfumery.com
# SANCTUM_STATEFUL_DOMAINS=buttercupperfumery.com
# PUBLIC_API_URL=https://api.buttercupperfumery.com/api
