# ─── Buttercup Perfumery — production env template ──────────────────────────
#
# Copy to `.env.production` (which is gitignored) before `npm run build` and
# fill in the real values. In Docker these are NOT used at runtime — the
# container entrypoint writes /usr/share/nginx/html/config.js from container
# env vars at startup, so the same image works in every environment.
#
# This file exists for the rare local `npm run build` that doesn't go through
# Docker, plus to document what `window.__CONFIG__` should contain in prod.

# Public API base URL. Same-origin reverse proxy (`/api/...` on the same host)
# is also fine — just leave the protocol+host off and use `/api`.
VITE_API_URL=https://api.buttercupperfumery.com/api

# Server-issued tracking key — see ANALYTICS_TRACKING_KEY in the API .env. The
# key is shipped to the browser, so don't reuse a secret-bearing one here.
VITE_TRACKING_API_KEY=

# Optional Sentry browser DSN. Empty string keeps Sentry disabled.
VITE_SENTRY_DSN=
