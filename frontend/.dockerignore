# Files that have no business inside the Docker build context. Excluding
# them keeps `docker build` fast (smaller context = faster send to daemon)
# and prevents stale local artifacts from poisoning the image.

# Local dependency cache — re-resolved by `npm ci` in the build stage.
node_modules

# Local build artifacts — the image runs `npm run build` from clean.
dist

# Local environment files — runtime values come from compose env.
.env
.env.*
!.env.example
!.env.production.example

# Vite cache.
.vite/

# Editor / IDE.
.idea/
.vscode/
*.iml

# VCS metadata.
.git
.gitattributes
.gitignore

# OS junk.
.DS_Store
Thumbs.db

# npm / yarn debug logs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Tests / coverage / cache.
coverage/
.nyc_output/
